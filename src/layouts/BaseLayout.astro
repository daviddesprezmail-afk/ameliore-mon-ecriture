---
import "../styles/global.css";

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <header style="background: white; border-bottom: 1px solid #e2e8f0;">
      <div
        style="
          max-width: 900px;
          margin: 0 auto;
          padding: 16px 20px;
          display: flex;
          justify-content: space-between;
          align-items: center;
        "
      >
        <a href="/" style="font-weight: 700; text-decoration: none; color: #1f2933;">
          Améliore mon écriture
        </a>

        <nav style="display: flex; gap: 18px;">
          <a href="/" style="text-decoration: none; color: #334e68; font-weight: 600;">
            Accueil
          </a>
          <a href="/contact" style="text-decoration: none; color: #334e68; font-weight: 600;">
            Contact
          </a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>
  </body>
</html>
